geom_point(x = tunedElasticPars$x$s,
y = tunedElasticPars$x$alpha,
col = "white", size = 3) +
theme_bw()
# Step 4:
tunedElastic      <- setHyperPars(elastic, par.vals = tunedElasticPars$x)
tunedElasticModel <- train(tunedElastic, iowaTask)
# Step 5:
elasticModelData <- getLearnerModel(tunedElasticModel)
elasticCoefs     <- coef(elasticModelData, s = tunedElasticPars$x$s)
coefTib$Elastic <- as.vector(elasticCoefs)[-1]
coef_long3 <- pivot_longer(coefTib,
names_to  = "Model",
values_to = "Beta",
-Coef)
ggplot(coef_long3, aes(x = reorder(Coef, Beta),
y = Beta,
fill = Model)) +
geom_bar(stat = "identity") +
facet_wrap(~Model) +
theme_bw() +
theme(legend.position = "none")
# Step 1:
ridgeWrapper <- makeTuneWrapper(ridge,
resampling = cvForTuning,
par.set    = ridgeParamSpace,
measures   = list(mae, mse, rmse),
control    = randSearch)
lassoWrapper <- makeTuneWrapper(lasso,
resampling = cvForTuning,
par.set    = lassoParamSpace,
measures   = list(mae, mse, rmse),
control    = randSearch)
elasticWrapper <- makeTuneWrapper(elastic,
resampling = cvForTuning,
par.set    = elasticParamSpace,
measures   = list(mae, mse, rmse),
control    = randSearch500)
# Step 2:
learners <- list(ridgeWrapper, lassoWrapper, elasticWrapper,
makeLearner("regr.lm"))
outerCV <- makeResampleDesc("CV", iters = 3)
parallelStartMulticore(cpus = detectCores())
benchmarkResult <- benchmark(learners, iowaTask, outerCV,
measures = list(mae, mse, rmse))
parallelStop()
benchmarkResult
plotBMRBoxplots(benchmarkResult, pretty.names = FALSE)
# Exercise 1
# ขยาย search space เป็น s = 0–50 เพื่อตรวจสอบว่าเดิมหา global minimum หรือแค่ local minimum
ridgeParamSpace2 <- makeParamSet(makeNumericParam("s", lower = 0, upper = 50))
parallelStartMulticore(cpus = detectCores())
tunedRidgePars2 <- tuneParams(ridge,
task      = iowaTask,
resampling = cvForTuning,
par.set   = ridgeParamSpace2,
measures  = list(mae, mse, rmse),
control   = randSearch)
parallelStop()
tunedRidgePars2
ridgeTuningData2 <- generateHyperParsEffectData(tunedRidgePars2)
plotHyperParsEffect(ridgeTuningData2,
x = "s",
y = "rmse.test.rmse",
plot.type = "line") +
theme_bw()
# ถ้า minimum ยังอยู่ในช่วง 5–7.5 เหมือนเดิม แสดงว่าค้นหา global minimum ได้แล้ว
# ถ้า RMSE ยังลดลงอยู่ในช่วง > 15 แสดงว่าเดิมเจอแค่ local minimum
# Exercise 2
# Contour plot with show.experiments = TRUE
plotHyperParsEffect(elasticTuningData,
x = "s",
y = "alpha",
z = "rmse.test.rmse",
plot.type = "contour",
interpolate = "regr.kknn",
show.experiments = TRUE) +
scale_fill_gradientn(colours = terrain.colors(10)) +
theme_bw()
# Scatter plot (ลบ interpolate, show.experiments, และ scale_fill_gradientn ออก)
plotHyperParsEffect(elasticTuningData,
x = "s",
y = "alpha",
z = "rmse.test.rmse",
plot.type = "scatter") +
theme_bw()
# Exercise 3
# (a) สร้าง tibble ที่มีแค่ Yield และ task ใหม่ (intercept-only model)
yieldTib  <- tibble(Yield = iowaTib$Yield)
yieldTask <- makeRegrTask(data = yieldTib, target = "Yield")
# (b) Train OLS บน yieldTask (model ที่ไม่มี predictor เลย ใช้แค่ intercept)
ols <- makeLearner("regr.lm")
# (c) Train LASSO บน iowaTask เดิม แต่กำหนด lambda = 500 (penalize สูงมาก → slopes → 0)
lassoHighLambda <- setHyperPars(lasso, par.vals = list(s = 500))
# (d) Cross-validate ทั้งคู่ด้วย Leave-One-Out (LOO)
looCV <- makeResampleDesc("LOO")
olsLOO   <- resample(ols,            yieldTask, looCV, measures = list(mse))
lassoLOO <- resample(lassoHighLambda, iowaTask,  looCV, measures = list(mse))
cat("OLS (intercept only) LOO MSE :", olsLOO$aggr,   "\n")
cat("LASSO (s=500)        LOO MSE :", lassoLOO$aggr, "\n")
# ทั้งสอง model ควรได้ MSE ใกล้เคียงกัน เพราะ LASSO ที่ lambda=500
# จะ shrink slopes ทุกตัวเข้าใกล้ 0 จนกลายเป็น intercept-only model
# Exercise 4
library(plotmo)
plotres(ridgeModelData)
plotres(lassoModelData)
plotres(elasticModelData)
