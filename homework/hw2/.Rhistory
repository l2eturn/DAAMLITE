library(tidyverse)
library(mlr)
library(glmnet)
library(plotmo)
library(parallel)
library(parallelMap)
knitr::opts_chunk$set(echo = TRUE)
Iowa <- read.csv("iowa.csv")
iowaTib <- as_tibble(Iowa)
iowaTib
iowa_long <- pivot_longer(iowaTib,
names_to = "Variable",
values_to = "Value",
-Yield)
ggplot(iowa_long, aes(Value, Yield)) +
facet_wrap(~ Variable, scales = "free_x") +
geom_point(size = 0.5) +
geom_smooth(method = "lm") +
theme_bw()
install.packages("kknn")
packages <- c("tidyverse", "tidymodels", "mlr", "mlr3", "mlr3learners",
"mlbench", "glmnet", "plotmo", "xgboost", "randomForest",
"corrplot", "janitor", "lubridate", "formatR", "knitr", "rmarkdown",
"kknn")
#nstalled_packages <- packages %in% rownames(installed.packages())
#install.packages(c("RcppArmadillo", "mvtnorm", "timereg"))
#if (any(installed_packages == FALSE)) {
#install.packages(packages[!installed_packages], dependencies = TRUE)
#}
library(tidyverse)
library(mlr)
iowaTask <- makeRegrTask(data = iowaTib, target = "Yield")
ridge <- makeLearner("regr.glmnet", alpha = 0, id = "ridge")
filterVals <- generateFilterValuesData(iowaTask,
method = "randomForest_importance")
plotFilterValues(filterVals) + theme_bw()
ridgeParamSpace <- makeParamSet(makeNumericParam("s", lower = 0, upper = 15))
randSearch <- makeTuneControlRandom(maxit = 200)
cvForTuning <- makeResampleDesc("RepCV", folds = 3, reps = 10)
parallelStartMulticore(cpus = detectCores())
tunedRidgePars <- tuneParams(ridge,
task = iowaTask,
resampling = cvForTuning,
par.set = ridgeParamSpace,
measures = list(mae, mse, rmse),
control = randSearch)
parallelStop()
tunedRidgePars
ridgeTuningData <- generateHyperParsEffectData(tunedRidgePars)
plotHyperParsEffect(ridgeTuningData,
x = "s",
y = "rmse.test.rmse",
plot.type = "line") +
theme_bw()
tunedRidge <- setHyperPars(ridge, par.vals = tunedRidgePars$x)
tunedRidgeModel <- train(tunedRidge, iowaTask)
ridgeModelData <- getLearnerModel(tunedRidgeModel)
# plot(ridgeModelData, xvar = "lambda", label = TRUE)
# plot(ridgeModelData, xvar = "norm", label = TRUE)
ridgeCoefs <- coef(ridgeModelData, s = tunedRidgePars$x$s)
ridgeCoefs
lmCoefs <- coef(lm(Yield ~ ., data = iowaTib))
lmCoefs
coefTib <- tibble(Coef = rownames(ridgeCoefs)[-1],
Ridge = as.vector(ridgeCoefs)[-1],
Lm = as.vector(lmCoefs)[-1])
coef_long <- pivot_longer(coefTib,
names_to = "Model",
values_to = "Beta",
-Coef)
ggplot(coef_long, aes(x = reorder(Coef, Beta),
y = Beta,
fill = Model)) +
geom_bar(stat = "identity") +
facet_wrap(~Model) +
theme_bw()  +
theme(legend.position = "none")
# Step 1:
lasso <- makeLearner("regr.glmnet", alpha = 1, id = "lasso")
# Step 2:
lassoParamSpace <- makeParamSet(makeNumericParam("s", lower = 0, upper = 15))
parallelStartMulticore(cpus = detectCores())
tunedLassoPars <- tuneParams(lasso,
task = iowaTask,
resampling = cvForTuning,
par.set = lassoParamSpace,
measures = list(mae, mse, rmse),
control = randSearch)
parallelStop()
tunedLassoPars
# Step 3:
lassoTuningData <- generateHyperParsEffectData(tunedLassoPars)
plotHyperParsEffect(lassoTuningData,
x = "s",
y = "rmse.test.rmse",
plot.type = "line") +
theme_bw()
# Step 4:
tunedLasso     <- setHyperPars(lasso, par.vals = tunedLassoPars$x)
tunedLassoModel <- train(tunedLasso, iowaTask)
# Step 5:
lassoModelData <- getLearnerModel(tunedLassoModel)
lassoCoefs     <- coef(lassoModelData, s = tunedLassoPars$x$s)
coefTib$LASSO <- as.vector(lassoCoefs)[-1]
coef_long2 <- pivot_longer(coefTib,
names_to  = "Model",
values_to = "Beta",
-Coef)
ggplot(coef_long2, aes(x = reorder(Coef, Beta),
y = Beta,
fill = Model)) +
geom_bar(stat = "identity") +
facet_wrap(~Model) +
theme_bw() +
theme(legend.position = "none")
# Step 1:
elastic <- makeLearner("regr.glmnet", id = "elastic")
# Step 2:
elasticParamSpace <- makeParamSet(makeNumericParam("s", lower = 0, upper = 10),
makeNumericParam("alpha", lower = 0, upper = 1))
randSearch500 <- makeTuneControlRandom(maxit = 500)
parallelStartMulticore(cpus = detectCores())
tunedElasticPars <- tuneParams(elastic,
task = iowaTask,
resampling = cvForTuning,
par.set = elasticParamSpace,
measures = list(mae, mse, rmse),
control = randSearch500)
parallelStop()
tunedElasticPars
# Step 3:
elasticTuningData <- generateHyperParsEffectData(tunedElasticPars)
plotHyperParsEffect(elasticTuningData,
x = "s",
y = "alpha",
z = "rmse.test.rmse",
plot.type = "heatmap",
interpolate = "regr.kknn") +
scale_fill_gradientn(colours = terrain.colors(10)) +
geom_point(x = tunedElasticPars$x$s,
y = tunedElasticPars$x$alpha,
col = "white", size = 3) +
theme_bw()
# Step 4:
tunedElastic      <- setHyperPars(elastic, par.vals = tunedElasticPars$x)
tunedElasticModel <- train(tunedElastic, iowaTask)
# Step 5:
elasticModelData <- getLearnerModel(tunedElasticModel)
elasticCoefs     <- coef(elasticModelData, s = tunedElasticPars$x$s)
coefTib$Elastic <- as.vector(elasticCoefs)[-1]
coef_long3 <- pivot_longer(coefTib,
names_to  = "Model",
values_to = "Beta",
-Coef)
ggplot(coef_long3, aes(x = reorder(Coef, Beta),
y = Beta,
fill = Model)) +
geom_bar(stat = "identity") +
facet_wrap(~Model) +
theme_bw() +
theme(legend.position = "none")
# Step 1:
